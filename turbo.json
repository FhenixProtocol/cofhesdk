{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "HOME",
    "USERPROFILE",
    "VOCS_BASE_URL",
    "COFHE_CHAIN_ID",
    "VITE_COFHE_CHAIN_ID",
    "LOCALCOFHE_HOST_CHAIN_RPC",
    "LOCALCOFHE_PRIVATE_KEY",
    "TEST_PRIVATE_KEY"
  ],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "dependsOn": ["^build"],
      "env": ["HOME", "USERPROFILE", "VOCS_BASE_URL"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "COFHE_CHAIN_ID",
        "VITE_COFHE_CHAIN_ID",
        "LOCALCOFHE_HOST_CHAIN_RPC",
        "LOCALCOFHE_PRIVATE_KEY",
        "TEST_PRIVATE_KEY"
      ]
    },
    "lint": {
      "env": ["HOME", "USERPROFILE", "VOCS_BASE_URL"]
    },
    "check:types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["HOME", "USERPROFILE", "VOCS_BASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
