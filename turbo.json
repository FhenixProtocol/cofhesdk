{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["HOME", "USERPROFILE", "VOCS_BASE_URL"],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "dependsOn": ["^build"],
      "env": ["HOME", "USERPROFILE", "VOCS_BASE_URL"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "env": ["HOME", "USERPROFILE", "VOCS_BASE_URL"]
    },
    "check:types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["HOME", "USERPROFILE", "VOCS_BASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
