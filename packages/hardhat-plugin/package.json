{
  "name": "@cofhe/hardhat-plugin",
  "version": "0.4.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FhenixProtocol/cofhesdk.git",
    "directory": "packages/hardhat-plugin"
  },
  "files": [
    "dist/**",
    "src/**",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --watch --dts",
    "lint": "eslint \"src/**/*.ts*\"",
    "check:types": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@cofhe/sdk": "workspace:*",
    "@cofhe/mock-contracts": "workspace:*",
    "chalk": "4.1.2",
    "fast-glob": "3.3.2",
    "viem": "2.38.6",
    "chai": "4.5.0"
  },
  "devDependencies": {
    "@cofhe/tsconfig": "workspace:*",
    "@cofhe/eslint-config": "workspace:*",
    "@nomicfoundation/hardhat-ethers": "3.1.0",
    "@nomicfoundation/hardhat-verify": "2.1.1",
    "@types/chai": "4.3.20",
    "@types/fs-extra": "11.0.4",
    "@types/node": "20.19.15",
    "@types/sinon": "17.0.4",
    "eslint": "8.57.1",
    "fs-extra": "11.3.2",
    "hardhat": "2.26.3",
    "hardhat-gas-reporter": "2.3.0",
    "prettier": "3.2.5",
    "prettier-plugin-solidity": "1.4.3",
    "tsup": "8.0.2",
    "typescript": "5.5.4"
  },
  "peerDependencies": {
    "hardhat": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "ethers": "^5.0.0 || ^6.0.0",
    "@fhenixprotocol/cofhe-contracts": ">=0.1.0",
    "@openzeppelin/contracts": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@fhenixprotocol/cofhe-contracts": {
      "optional": false
    },
    "@openzeppelin/contracts": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
